"use client";

import { useEffect,useState } from "react";
import Image from "next/image";
import { useSearchParams } from "next/navigation";
import { saveProduct,updateProduct,getProduct } from "@/lib/adminProducts";
import { storage } from "@/lib/firebase";
import { ref,uploadBytes,getDownloadURL } from "firebase/storage";

export default function ProductEditor(){

const params=useSearchParams();
const id=params.get("id");

const [uploading,setUploading]=useState(false);

const [product,setProduct]=useState<any>({
 name:"",
 category:"",
 description:"",
 image:"",
 price:0,
 featured:false,
 trending:false,
 bestseller:false,
 brand:"",

gender:"",

discount:0,

currency:"PKR",

tags:[],

material:"",

weight:0,

seoTitle:"",

seoDescription:"",

comparePrice:0,

sku:"",
newArrival:false
});

useEffect(()=>{
 async function load(){
   if(!id) return;
   const data=await getProduct(id);
   if(data) setProduct(data);
 }
 load();
},[id]);

async function uploadImage(file:any){

 setUploading(true);

 const storageRef=ref(
   storage,
   `products/${Date.now()}-${file.name}`
 );

 await uploadBytes(storageRef,file);

 const url=
   await getDownloadURL(storageRef);

 setProduct({
   ...product,
   image:url
 });

 setUploading(false);
}

async function save(){

 if(!product.name){
   alert("Please enter product name");
   return;
 }

 if(!product.category){
   alert("Please enter category");
   return;
 }

 if(product.price<=0){
   alert("Please enter valid price");
   return;
 }

 if(id){
   await updateProduct(id,product);
   alert("Updated");
 }else{
   await saveProduct(product);
   alert("Created");
 }

}
return(
<div className="max-w-5xl mx-auto p-10">

<h1 className="text-4xl font-black mb-8">
Product Editor
</h1>

<div className="grid gap-4">

<input
className="border p-4 rounded-xl"
placeholder="Product Name"
value={product.name || ""}
onChange={e=>setProduct({...product,name:e.target.value})}
/>

<input
className="border p-4 rounded-xl"
placeholder="Category"
value={product.category || ""}
onChange={e=>setProduct({...product,category:e.target.value})}
/>

<input
className="border p-4 rounded-xl"
placeholder="Brand"
value={product.brand || ""}
onChange={e=>setProduct({...product,brand:e.target.value})}
/>

<input
className="border p-4 rounded-xl"
placeholder="SKU"
value={product.sku || ""}
onChange={e=>setProduct({...product,sku:e.target.value})}
/>

<textarea
className="border p-4 rounded-xl"
rows={5}
placeholder="Description"
value={product.description || ""}
onChange={e=>setProduct({...product,description:e.target.value})}
/>

<div className="grid grid-cols-3 gap-4">

<input
className="border p-4 rounded-xl"
type="number"
placeholder="Price"
value={product.price || 0}
onChange={e=>setProduct({...product,price:Number(e.target.value)})}
/>

<input
className="border p-4 rounded-xl"
type="number"
placeholder="Compare Price"
value={product.comparePrice || 0}
onChange={e=>setProduct({...product,comparePrice:Number(e.target.value)})}
/>

<input
className="border p-4 rounded-xl"
type="number"
placeholder="Discount %"
value={product.discount || 0}
onChange={e=>setProduct({...product,discount:Number(e.target.value)})}
/>

</div>

<select
className="border p-4 rounded-xl"
value={product.gender || ""}
onChange={e=>setProduct({...product,gender:e.target.value})}
>
<option value="">Select Gender</option>
<option value="Men">Men</option>
<option value="Women">Women</option>
<option value="Kids">Kids</option>
<option value="Unisex">Unisex</option>
</select>

<input
className="border p-4 rounded-xl"
placeholder="Material"
value={product.material || ""}
onChange={e=>setProduct({...product,material:e.target.value})}
/>

<input
className="border p-4 rounded-xl"
type="number"
placeholder="Weight"
value={product.weight || 0}
onChange={e=>setProduct({...product,weight:Number(e.target.value)})}
/>

<input
className="border p-4 rounded-xl"
placeholder="Tags (comma separated)"
value={(product.tags || []).join(",")}
onChange={e=>setProduct({
...product,
tags:e.target.value
.split(",")
.map((x:string)=>x.trim())
.filter(Boolean)
})}
/>

<input
className="border p-4 rounded-xl"
placeholder="SEO Title"
value={product.seoTitle || ""}
onChange={e=>setProduct({...product,seoTitle:e.target.value})}
/>

<textarea
className="border p-4 rounded-xl"
rows={3}
placeholder="SEO Description"
value={product.seoDescription || ""}
onChange={e=>setProduct({...product,seoDescription:e.target.value})}
/>

<div>

<label className="font-semibold mb-2 block">
Main Product Image
</label>

<input
type="file"
onChange={e=>{
const file=e.target.files?.[0];
if(file) uploadImage(file);
}}
/>

</div>

{uploading &&
<div className="text-blue-600 font-semibold">
Uploading...
</div>
}


{product.image && (

<Image
src={product.image}
alt="Product"
width={256}
height={256}
className="w-64 h-64 object-cover rounded-xl border"
/>

)}

<div className="grid grid-cols-2 md:grid-cols-4 gap-4">

<label className="flex gap-2 items-center">
<input
type="checkbox"
checked={product.featured}
onChange={e=>setProduct({...product,featured:e.target.checked})}
/>
Featured
</label>

<label className="flex gap-2 items-center">
<input
type="checkbox"
checked={product.trending}
onChange={e=>setProduct({...product,trending:e.target.checked})}
/>
Trending
</label>

<label className="flex gap-2 items-center">
<input
type="checkbox"
checked={product.newArrival}
onChange={e=>setProduct({...product,newArrival:e.target.checked})}
/>
New Arrival
</label>

<label className="flex gap-2 items-center">
<input
type="checkbox"
checked={product.bestseller || false}
onChange={e=>setProduct({...product,bestseller:e.target.checked})}
/>
Best Seller
</label>

</div>

<button
disabled={uploading}
onClick={save}
className="bg-black text-white p-4 rounded-xl hover:bg-gray-800"
>
{uploading ? "Uploading..." : "Save Product"}
</button>

</div>
</div>
);
}

